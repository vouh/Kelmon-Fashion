# Copy to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Firebase (client — safe for browser) ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server only — from service account JSON) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private key with \n for line breaks, or use real newlines in quotes
FIREBASE_PRIVATE_KEY=

# ─── M-Pesa Daraja API ───
# sandbox | production
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a public HTTPS URL in production (use ngrok for local testing)
MPESA_CALLBACK_URL=http://localhost:3001/api/mpesa/callback

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3001
